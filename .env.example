# Copy this file to `.env` and fill in your Atlas connection strings.
# Both clusters must be replica sets (any Atlas tier qualifies).

SOURCE_URI=mongodb+srv://<user>:<pass>@<source-cluster>/?retryWrites=true&w=majority
TARGET_URI=mongodb+srv://<user>:<pass>@<target-cluster>/?retryWrites=true&w=majority

SOURCE_DB=sourceDb
SOURCE_COLLECTION=products

TARGET_DB=targetDb
TARGET_COLLECTION=products

# Collection in the target DB used to persist the change-stream resume token.
RESUME_STATE_COLLECTION=_replication_state

# Logical id for this replication pipeline (allows running multiple in parallel).
PIPELINE_ID=products_default
